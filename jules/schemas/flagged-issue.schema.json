{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ZOLAtheCodeX/aigovclaw/jules/schemas/flagged-issue.schema.json",
  "title": "FlaggedIssue",
  "description": "Record describing a single Jules maintenance task. See docs/jules-integration-design.md Section 3.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "source",
    "playbook",
    "target_repo",
    "target_branch",
    "priority",
    "created_at",
    "state",
    "retry_count",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3,
      "description": "Stable unique identifier. ULID or uuid-derived."
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable type label for the issue."
    },
    "source": {
      "type": "string",
      "enum": ["claude-code", "human", "scheduled", "framework-monitor", "ci"],
      "description": "What produced this record."
    },
    "playbook": {
      "type": "string",
      "enum": [
        "framework-drift",
        "test-coverage-gap",
        "dep-bump",
        "citation-drift",
        "markdown-lint",
        "new-plugin-scaffold",
        "link-toc",
        "prohibited-content-sweep"
      ]
    },
    "target_repo": {
      "type": "string",
      "minLength": 3,
      "description": "GitHub repo slug, for example ZOLAtheCodeX/aigovops."
    },
    "target_branch": {
      "type": "string",
      "minLength": 1,
      "default": "main"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high"]
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "state": {
      "type": "string",
      "enum": [
        "flagged",
        "queued",
        "dispatched",
        "in-progress",
        "draft-pr",
        "reviewed",
        "merged",
        "failed",
        "escalated",
        "rejected"
      ]
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "session_id": {
      "type": ["string", "null"]
    },
    "session_url": {
      "type": ["string", "null"]
    },
    "pr_url": {
      "type": ["string", "null"]
    },
    "final_state": {
      "type": ["string", "null"],
      "enum": ["merged", "rejected", "escalated", null]
    },
    "audit_event_id": {
      "type": ["string", "null"]
    },
    "payload": {
      "type": "object",
      "description": "Playbook-specific structured input. Shape depends on playbook."
    }
  }
}
