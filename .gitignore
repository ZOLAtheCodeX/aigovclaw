# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors and OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Node (in case any adapter or script adds JS tooling later)
node_modules/
.markdownlint-cli2-cache/

# Hermes workspace (when developers run install.sh locally for testing)
.hermes-local/

# Jules dispatcher state (active records and archives). Keep .gitkeep files.
jules/flagged/*.json
jules/archive/**
!jules/flagged/.gitkeep
!jules/archive/.gitkeep

# Hub generator output
hub/output/


# Demo outputs: the current set under demos/*/output/ is committed as a
# reference of what the last known good run produced. Subsequent local
# runs write new timestamped files alongside those; keep them out of
# git status so the working tree stays quiet.
demos/*/output/*
!demos/*/output/
!demos/*/output/.keep
